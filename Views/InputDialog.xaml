<Window x:Class="AchievementTranslator.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajouter une langue" Height="200" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#2A2A3E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Code of the new language (ex : fr_fr, de_de, es_es) :"
                   Foreground="#CDD6F4" FontSize="13" TextWrapping="Wrap"/>

        <TextBox x:Name="InputBox" Grid.Row="2"
                 Background="#313145" Foreground="#CDD6F4"
                 BorderBrush="#45475A" BorderThickness="1"
                 Padding="8,6" FontSize="14"
                 CaretBrush="#89B4FA"
                 KeyDown="InputBox_KeyDown"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="Add" Width="90" Height="32" Margin="0,0,10,0"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand" Click="OkButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Cancel" Width="90" Height="32"
                    Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0" Cursor="Hand" Click="CancelButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
