<Window x:Class="AchievementTranslator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AchievementTranslator.ViewModels"
        xmlns:local="clr-namespace:AchievementTranslator.Views"
        Title="Achievement Translation Editor"
        Height="820" Width="1320"
        MinHeight="600" MinWidth="920"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- ── Brushes ── -->
        <SolidColorBrush x:Key="BgBase"      Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgSurface"   Color="#2A2A3E"/>
        <SolidColorBrush x:Key="BgElevated"  Color="#313145"/>
        <SolidColorBrush x:Key="AccentBlue"  Color="#89B4FA"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#A6E3A1"/>
        <SolidColorBrush x:Key="AccentRed"   Color="#F38BA8"/>
        <SolidColorBrush x:Key="AccentAmber" Color="#F9E2AF"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#CBA6F7"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#A6ADC8"/>
        <SolidColorBrush x:Key="TextFaint"   Color="#6C7086"/>
        <SolidColorBrush x:Key="BorderCol"   Color="#45475A"/>

        <!-- ── Converters ── -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Button template helper ── -->
        <ControlTemplate x:Key="RoundBtnTpl" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.60"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.30"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Ghost button -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"  Value="#45475A"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"     Value="13,7"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template"    Value="{StaticResource RoundBtnTpl}"/>
        </Style>

        <!-- Accent button -->
        <Style x:Key="BtnAccent" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Purple button -->
        <Style x:Key="BtnPurple" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
            <Setter Property="Background" Value="{StaticResource AccentPurple}"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
        </Style>

        <!-- Dark TextBox -->
        <Style x:Key="TbxDark" TargetType="TextBox">
            <Setter Property="Background"            Value="#313145"/>
            <Setter Property="Foreground"            Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"           Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="Padding"               Value="8,6"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="CaretBrush"            Value="{StaticResource AccentBlue}"/>
            <Setter Property="SelectionBrush"        Value="#4489B4FA"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ReadOnly TextBox -->
        <Style x:Key="TbxRO" TargetType="TextBox" BasedOn="{StaticResource TbxDark}">
            <Setter Property="Background"  Value="#252535"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="BorderBrush" Value="#2A2A3E"/>
            <Setter Property="IsReadOnly"  Value="True"/>
            <Setter Property="Focusable"   Value="False"/>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="CbxDark" TargetType="ComboBox">
            <Setter Property="Background"      Value="#313145"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>

        <!-- CheckBox -->
        <Style x:Key="ChkDark" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <!-- TreeViewItem with full custom template -->
        <Style x:Key="TviStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded"  Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border x:Name="Bd" Grid.Row="0" CornerRadius="4" Margin="2,1"
                                    Background="{TemplateBinding Background}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Exp" Grid.Column="0"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press" Focusable="False">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <TextBlock x:Name="Arr" Text="▶" FontSize="8"
                                                           Foreground="#6C7086"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arr" Property="Text" Value="▼"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                      VerticalAlignment="Center"
                                                      Margin="0,3,4,3"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="Items" Grid.Row="1"
                                            Margin="18,0,0,0" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="Items" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Exp" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D3D5A"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"  Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E42"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="S"   Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="Tab" Modifiers="Ctrl" Command="{Binding NextUntranslatedCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>  <!-- Toolbar -->
            <RowDefinition Height="6"/>   <!-- Progress bar -->
            <RowDefinition Height="*"/>   <!-- Content -->
            <RowDefinition Height="28"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ════════════════════ TOOLBAR ════════════════════ -->
        <Border Grid.Row="0" Background="#2A2A3E"
                BorderBrush="{StaticResource BorderCol}" BorderThickness="0,0,0,1">
            <DockPanel Margin="14,0" LastChildFill="False" VerticalAlignment="Center">

                <!-- Title -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBlock Text="🎮" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Achievement Translator" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Load -->
                <Button DockPanel.Dock="Left" Content="📂  Charger" Margin="0,0,8,0"
                        Style="{StaticResource BtnGhost}" Command="{Binding LoadFilesCommand}"
                        ToolTip="Ouvrir AchievementInfoMap.json + AchievementStringMap.json"/>

                <!-- Language selector -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Text="Langue :" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,7,0" FontSize="13"/>
                    <ComboBox Style="{StaticResource CbxDark}" Width="115"
                              ItemsSource="{Binding Languages}"
                              SelectedItem="{Binding SelectedLanguage}"/>
                </StackPanel>

                <!-- Add language -->
                <Button DockPanel.Dock="Left" Content="＋ Langue" Margin="0,0,8,0"
                        Style="{StaticResource BtnPurple}" Command="{Binding AddLanguageCommand}"
                        ToolTip="Ajouter un nouveau code langue au fichier"/>

                <!-- Save -->
                <Button DockPanel.Dock="Left" Content="💾  Enregistrer" Margin="0,0,8,0"
                        Style="{StaticResource BtnAccent}" Command="{Binding SaveCommand}"
                        ToolTip="Ctrl+S"/>

                <!-- Next untranslated -->
                <Button DockPanel.Dock="Left" Content="⏭  Suivant non traduit"
                        Style="{StaticResource BtnGhost}"
                        Command="{Binding NextUntranslatedCommand}" ToolTip="Ctrl+Tab"/>

                <!-- Stats button -->
                <Button DockPanel.Dock="Right" Content="📊  Stats" Margin="8,0,0,0"
                        Style="{StaticResource BtnGhost}" Command="{Binding ShowStatsCommand}"
                        ToolTip="Progression par catégorie"/>

                <!-- Progress badge -->
                <Border DockPanel.Dock="Right" Background="#1E1E2E"
                        CornerRadius="6" Padding="12,6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓ " Foreground="{StaticResource AccentGreen}" FontSize="13"/>
                        <TextBlock Text="{Binding ProgressText}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

            </DockPanel>
        </Border>

        <!-- ════════════════════ PROGRESS BAR ════════════════════ -->
        <ProgressBar Grid.Row="1" Height="6"
                     Value="{Binding ProgressPercent, Mode=OneWay}"
                     Minimum="0" Maximum="100"
                     Background="#181825"
                     Foreground="{StaticResource AccentGreen}"
                     BorderThickness="0"/>

        <!-- ════════════════════ CONTENT ════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="180"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: TreeView ─── -->
            <Grid Grid.Column="0" Background="#252535">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search -->
                <Border Grid.Row="0" Padding="8,8,8,6"
                        BorderBrush="{StaticResource BorderCol}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBox x:Name="SearchBox" Style="{StaticResource TbxDark}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="🔍  Rechercher par nom anglais…"
                                   Foreground="{StaticResource TextFaint}" FontSize="12"
                                   Margin="10,0" VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Filter -->
                <Border Grid.Row="1" Padding="10,6"
                        BorderBrush="{StaticResource BorderCol}" BorderThickness="0,0,0,1">
                    <CheckBox Style="{StaticResource ChkDark}"
                              IsChecked="{Binding ShowOnlyUntranslated}">
                        <TextBlock Text="Afficher uniquement non traduits"
                                   Foreground="{StaticResource TextMuted}"/>
                    </CheckBox>
                </Border>

                <!-- Tree -->
                <TreeView x:Name="AchievementTree" Grid.Row="2"
                          Background="Transparent" BorderThickness="0"
                          ItemsSource="{Binding RootNodes}"
                          ItemContainerStyle="{StaticResource TviStyle}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <Grid Margin="0,1,4,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Node label -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding DisplayName}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding DisplayName}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasMissingTranslations}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentAmber}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                                    <Setter Property="Opacity" Value="0.40"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Red dot indicator -->
                                <Ellipse Grid.Column="1" Width="6" Height="6"
                                         Fill="{StaticResource AccentRed}"
                                         Margin="5,0,2,0" VerticalAlignment="Center"
                                         Visibility="{Binding HasMissingTranslations, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderCol}" Cursor="SizeWE"/>

            <!-- ─── RIGHT: Editor ─── -->
            <Grid Grid.Column="2" Background="{StaticResource BgBase}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Achievement header -->
                <Border Grid.Row="0" Background="{StaticResource BgSurface}"
                        BorderBrush="{StaticResource BorderCol}" BorderThickness="0,0,0,1"
                        Padding="20,12">
                    <Grid>
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNode}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Aucun achievement sélectionné"
                                   FontSize="15" Foreground="{StaticResource TextFaint}"/>
                    </StackPanel>
                    <!-- With selection -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNode}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{Binding SelectedNode.DisplayName}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBlue}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextFaint}">
                                <Run Text="ID :"/>
                                <Run Text="{Binding SelectedNode.Achievement.Id}"/>
                                <Run Text="   |   Ordre :"/>
                                <Run Text="{Binding SelectedNode.Achievement.DisplayOrder}"/>
                                <Run Text="   |   Activé :"/>
                            </TextBlock>
                            <TextBlock FontSize="11" Margin="4,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNode.Achievement.Enabled}" Value="True">
                                                <Setter Property="Text"       Value="✓ Oui"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedNode.Achievement.Enabled}" Value="False">
                                                <Setter Property="Text"       Value="✗ Non"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentRed}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource TextFaint}" FontSize="11" Margin="8,0,0,0">
                                <Run Text="   |   Cible :"/>
                            </TextBlock>
                            <TextBlock Text="{Binding SelectedLanguage}" FontSize="11"
                                       FontWeight="SemiBold" Margin="4,0,0,0"
                                       Foreground="{StaticResource AccentGreen}"/>
                        </StackPanel>
                    </StackPanel>
                        </Grid>
                </Border>

                <!-- Empty placeholder -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNode}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="🎯" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <TextBlock Text="Sélectionnez un achievement"
                               Foreground="{StaticResource TextFaint}" FontSize="16"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="dans l'arbre à gauche pour éditer ses traductions"
                               Foreground="#45475A" FontSize="13" HorizontalAlignment="Center"
                               Margin="0,5,0,20"/>
                    <Button Content="📂  Charger les fichiers JSON" Style="{StaticResource BtnGhost}"
                            Command="{Binding LoadFilesCommand}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Fields -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedNode}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl x:Name="FieldsList" ItemsSource="{Binding Fields}"
                                  Margin="20,14,20,20" Focusable="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12" Background="{StaticResource BgSurface}"
                                        CornerRadius="8" Padding="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Label row -->
                                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="{Binding FieldLabel}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBlue}"
                                                       VerticalAlignment="Center"/>
                                            <!-- Shared badge -->
                                            <Border DockPanel.Dock="Right"
                                                    Background="#2D1F3D" CornerRadius="4"
                                                    Padding="6,2" Margin="8,0,0,0"
                                                    Visibility="{Binding IsShared, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding SharedLabel}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource AccentPurple}"/>
                                            </Border>
                                        </DockPanel>

                                        <!-- English label -->
                                        <TextBlock Grid.Row="1" Text="🇬🇧  English (référence)"
                                                   FontSize="11" Foreground="{StaticResource TextFaint}"
                                                   Margin="0,0,0,4"/>
                                        <!-- English box -->
                                        <TextBox Grid.Row="2" Style="{StaticResource TbxRO}"
                                                 Text="{Binding EnglishText, Mode=OneWay}"
                                                 TextWrapping="Wrap" MinHeight="32"
                                                 Margin="0,0,0,10"/>

                                        <!-- Target label + missing badge -->
                                        <DockPanel Grid.Row="3" Margin="0,0,0,4">
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontSize="11" Foreground="{StaticResource TextFaint}">
                                                <Run Text="🌐  "/>
                                                <Run Text="{Binding DataContext.SelectedLanguage,
                                                             RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            </TextBlock>
                                            <Border DockPanel.Dock="Left" Background="#3D1A1F"
                                                    CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IsMissing, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="⚠ manquant" FontSize="10"
                                                           Foreground="{StaticResource AccentRed}"/>
                                            </Border>
                                        </DockPanel>

                                        <!-- Editable translation box -->
                                        <TextBox Grid.Row="4"
                                                 Text="{Binding TranslatedText, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap" MinHeight="34"
                                                 AcceptsReturn="True">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource TbxDark}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                            <Setter Property="Background"  Value="#2E1018"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentRed}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Grid>

        <!-- ════════════════════ STATUS BAR ════════════════════ -->
        <Border Grid.Row="3" Background="#181825"
                BorderBrush="{StaticResource BorderCol}" BorderThickness="0,1,0,0"
                Padding="16,0">
            <DockPanel LastChildFill="True" VerticalAlignment="Center">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <CheckBox Style="{StaticResource ChkDark}"
                              IsChecked="{Binding AutoSave}" Margin="0,0,16,0">
                        <TextBlock Text="Sauvegarde auto" Foreground="{StaticResource TextFaint}" FontSize="11"/>
                    </CheckBox>
                    <TextBlock Text="Ctrl+S : Enregistrer   |   Ctrl+Tab : Suivant non traduit"
                               Foreground="{StaticResource TextFaint}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextMuted}" FontSize="11"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
